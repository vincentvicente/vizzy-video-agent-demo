# Copy to .env and fill in your keys (never commit the real .env)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
FAL_KEY=your-fal-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Optional overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
# fal video model endpoint (default: Seedance v1 pro image-to-video)
FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1/pro/image-to-video
# override per-second cost estimate; otherwise inferred from the model
FAL_COST_PER_SECOND=
# ElevenLabs voice id (default: Rachel)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

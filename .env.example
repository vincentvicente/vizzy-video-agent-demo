# Copy to .env and fill in your keys (never commit the real .env)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ---------- Video generation provider ----------
# "fal" (default) or "volcano" (Volcengine Ark, Seedance 2.0)
VIDEO_PROVIDER=volcano

# --- fal provider (used when VIDEO_PROVIDER=fal) ---
FAL_KEY=your-fal-key-here
# fal video model endpoint (default: Seedance v1 pro image-to-video)
FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1/pro/image-to-video

# --- volcano provider (used when VIDEO_PROVIDER=volcano) ---
ARK_API_KEY=your-volcengine-ark-api-key-here
# China region (default). For BytePlus international, use:
#   ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
#   VOLCANO_VIDEO_MODEL=dreamina-seedance-2-0-260128
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_VIDEO_MODEL=doubao-seedance-2-0-260128
# 480p / 720p / 1080p / 2K
VOLCANO_RESOLUTION=1080p
# "reference_image" = identity/style anchor (good for cross-scene consistency); empty = literal first frame
VOLCANO_IMAGE_ROLE=reference_image

# ---------- Other ----------
ANTHROPIC_MODEL=claude-sonnet-4-6
# override per-second cost estimate; otherwise inferred from the model
VIDEO_COST_PER_SECOND=
# ElevenLabs voice id (default: Rachel)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
